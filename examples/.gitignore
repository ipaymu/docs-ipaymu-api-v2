# Example Projects - Git Ignore
# Build artifacts, dependencies, and runtime files

# Dependencies
node_modules/
vendor/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
build/
dist/
target/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/

# Environment files
.env
.env.local
.env.*.local
.env.development
.env.production

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# Go
*.o
*.a

# Python
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.mypy_cache/
.dmypy.json

# Rust
Cargo.lock

# PHP
composer.lock
composer.phar

# Testing
.test/
test-results/

# Temporary files
tmp/
temp/
*.tmp
